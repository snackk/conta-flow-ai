# Não é obrigatório preencher isto para testar localmente: em dev, se este ficheiro
# .env não existir (ou estas variáveis ficarem vazias), a app liga-se sozinha aos
# emuladores locais do Firebase (ver README > "Testar localmente sem projeto Firebase").

# JSON com a configuração do projeto Firebase (Project Settings > General > Your apps > SDK setup and configuration)
VITE_FIREBASE_CONFIG={"apiKey":"","authDomain":"","projectId":"","storageBucket":"","messagingSenderId":"","appId":""}

# Identificador opcional da aplicação, usado para namespacing de dados legados
VITE_APP_ID=conta-flow-ai

# Forçar ligação aos emuladores locais mesmo com VITE_FIREBASE_CONFIG preenchido
VITE_USE_FIREBASE_EMULATORS=false
